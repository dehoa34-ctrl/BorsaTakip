# ═══════════════════════════════════════════════════════
#  BorsaTakip Trading Bot — Ortam Değişkenleri Şablonu
#  Bu dosyayı kopyalayın: cp .env.example .env
#  Sonra değerleri doldurun
# ═══════════════════════════════════════════════════════

# ── Binance API ────────────────────────────────────────
# Binance hesabınızda API Management > Create API'den oluşturun
# Testnet için: https://testnet.binancefuture.com/
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Telegram Bot ───────────────────────────────────────
# 1. Telegram'da @BotFather'a gidin
# 2. /newbot komutunu çalıştırın, bot adı ve username verin
# 3. Aldığınız token'ı buraya yapıştırın
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Chat ID: Botunuza /start gönderin, sonra:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# JSON'da "chat":{"id": BURAYA_BAKACAKSINIZ}
TELEGRAM_CHAT_ID=-100123456789

# ── Bot Veritabanı ─────────────────────────────────────
BOT_DB_PATH=trading_bot/bot_trades.db

# ── Varsayılan Bot Ayarları ────────────────────────────
# Bu değerler arayüzden değiştirilebilir, sadece başlangıç için:
BOT_DEFAULT_MODE=paper
BOT_DEFAULT_STRATEGY=scalping
BOT_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
BOT_PORTFOLIO_VALUE=1000
